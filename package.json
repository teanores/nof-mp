{
  "name": "@nof/nof-mp",
  "version": "0.2.44",
  "private": true,
  "description": "NOF Main Platform portal, authentication, profile and global access management",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @nof/nof-mp-web run dev",
    "build": "npm --workspace @nof/nof-mp-web run build",
    "lint": "npm --workspace @nof/nof-mp-web run lint",
    "local:identity-env": "node scripts/local/identity-fixtures.mjs env",
    "local:identity-users": "node scripts/local/identity-fixtures.mjs users",
    "local:bootstrap-db": "node scripts/local/identity-fixtures.mjs bootstrap-db",
    "local:seed-identity": "node scripts/local/identity-fixtures.mjs seed",
    "local:reset-identity": "node scripts/local/identity-fixtures.mjs reset",
    "local:db-up": "docker compose -f compose.local.yml up -d postgres",
    "local:db-down": "docker compose -f compose.local.yml down",
    "local:db-reset": "docker compose -f compose.local.yml down -v && docker compose -f compose.local.yml up -d postgres",
    "local:db-logs": "docker compose -f compose.local.yml logs postgres",
    "smoke:identity": "npm --workspace @nof/nof-mp-web run smoke:identity",
    "test:identity": "npm --workspace @nof/nof-mp-web run test:identity",
    "typecheck": "npm --workspace @nof/nof-mp-web run typecheck",
    "test": "npm --workspace @nof/nof-mp-web run test:run",
    "test:watch": "npm --workspace @nof/nof-mp-web run test",
    "check": "npm --workspace @nof/nof-mp-web run check"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    },
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
