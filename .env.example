# Safe examples only. Do not commit real secrets.
# Production-like public origin. Local/LAN overrides must be explicit and must
# not be copied into production or shared OAuth defaults.
NEXT_PUBLIC_PLATFORM_ORIGIN=https://forgath.ru

# Legacy internal bridge while nof-mp still talks to the decomposed nof-service backend.
# Keep internal-only; do not expose this URL in browser UI or public docs.
# Canonical internal alias for legacy nof-service bridge.
NOF_SERVICE_INTERNAL_URL=http://nof-service-internal:5000
DB_SERVER=postgres
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASS=
SECRET_KEY=
NOF_AUTH_SECRET_KEY=
NOF_PLATFORM_DATABASE_URL=
NOF_PLATFORM_DB_SCHEMA=nof_platform
NOF_PLATFORM_MCP_TOKEN_SECRET=

# Optional password reset email delivery webhook. Leave empty in local/dev unless
# a dedicated email service endpoint is configured.
NOF_MP_EMAIL_WEBHOOK_URL=
NOF_MP_EMAIL_WEBHOOK_TOKEN=
NOF_MP_EMAIL_FROM=accounts@forgath.ru
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Shared media storage (MinIO/S3-compatible). Values are examples/empty only.
NOF_MEDIA_S3_ENDPOINT=http://127.0.0.1:9000
NOF_MEDIA_S3_REGION=us-east-1
NOF_MEDIA_S3_ACCESS_KEY_ID=
NOF_MEDIA_S3_SECRET_ACCESS_KEY=
NOF_MEDIA_S3_BUCKET_NOF_MP=nof-mp
